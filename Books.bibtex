@book{
  title = {The {{Sagebrush Rebellion}} in {{Nevada}}},
  author = {{University of Nevada Oral History Program}},
  year = 2016,
  publisher = {University of Nevada Oral History Program},
  urldate = {2023-09-20},
  abstract = {The now famous grassroots Sagebrush Rebellion against Washington's control over vast stretches of western land was conceived in reaction to a series of federal laws issued in the late 1970s. As a state 86\% owned and operated by the federal government, Nevada was primed for opposition to federal control. These twelve oral history interviews with key players in Nevada's Sagebrush Rebellion were conducted between 1998 and 2001. Participants include ranchers, state legislators, federal government employees, activists, and tribal members.},
  copyright = {http://creativecommons.org/licenses/by-nc-nd/4.0/},
  langid = {english},
  keywords = {Nevada,Sagebrush Rebellion}
}

